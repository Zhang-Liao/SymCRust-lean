import Spec.SHA3.Spec

/-!
# Test vectors for SHA-3, from FIPS 202 and the NIST examples page.

All vectors use `#guard` so a wrong result fails `lake build`.
-/

open Spec.SHA3
open Spec (𝔹)

/-! ## SHA3-256 empty message

SHA3-256("") = a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a -/

private def sha3_256_empty_expected : 𝔹 32 :=
  #v[0xa7, 0xff, 0xc6, 0xf8, 0xbf, 0x1e, 0xd7, 0x66, 0x51, 0xc1, 0x47, 0x56, 0xa0, 0x61, 0xd6, 0x62,
     0xf5, 0x80, 0xff, 0x4d, 0xe4, 0x3b, 0x49, 0xfa, 0x82, 0xd8, 0x0a, 0x4b, 0x80, 0xf8, 0x43, 0x4a]

#guard sha3_256 (Vector.replicate 0 (0 : Byte)) == sha3_256_empty_expected


/-! ## SHA3-256("abc")

SHA3-256("abc") = 3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532 -/

private def abcMsg : 𝔹 3 := #v[0x61, 0x62, 0x63]

private def sha3_256_abc_expected : 𝔹 32 :=
  #v[0x3a, 0x98, 0x5d, 0xa7, 0x4f, 0xe2, 0x25, 0xb2, 0x04, 0x5c, 0x17, 0x2d, 0x6b, 0xd3, 0x90, 0xbd,
     0x85, 0x5f, 0x08, 0x6e, 0x3e, 0x9d, 0x52, 0x5b, 0x46, 0xbf, 0xe2, 0x45, 0x11, 0x43, 0x15, 0x32]

#guard sha3_256 abcMsg == sha3_256_abc_expected


