import Spec.MLKEM.Spec
import SpecTests.TestUtils

/-!
# ML-KEM test vectors

- `#guard` for fast unit-level checks (run during `lake build`).
- Expensive CAVP tests run native-compiled via `lake exe mlKemTests`.

-/

namespace Spec.MLKEM.Test

open Spec.MLKEM

/-! ## Fast unit tests (`#guard`) -/

#guard
  let b : Vector Bool (8 * 2) :=
    ⟨⟨[false, true, false, true, false, false, false, false,
      true, false, false, false, false, false, false, false]⟩, by simp⟩
  BytesToBits (BitsToBytes b) = b

#guard Compress 1 (0 : Zq) = (0 : ZMod (m 1))
#guard Decompress 1 (0 : ZMod (m 1)) = (0 : Zq)
#guard Compress 4 (Decompress 4 (7 : ZMod (m 4))) = (7 : ZMod (m 4))

#guard BaseCaseMultiply 1 0 1 0 (ζ : Zq) = ((1 : Zq), (0 : Zq))
#guard BaseCaseMultiply 0 1 0 1 (ζ : Zq) = (ζ, (0 : Zq))

#guard ByteDecode (ByteEncode 1 (Vector.replicate 256 (0 : ZMod (m 1)))) = Vector.replicate 256 0

#guard NTT Polynomial.zero = Polynomial.zero
#guard NTTInv Polynomial.zero = Polynomial.zero
#guard NTTInv (NTT Polynomial.zero) = Polynomial.zero

-- Appendix A spot checks: ζ^{BitRev7(i)} mod q
#guard (ζ ^ (bitRev 7 0) : Zq).val = 1
#guard (ζ ^ (bitRev 7 1) : Zq).val = 1729
#guard (ζ ^ (bitRev 7 64) : Zq).val = 17
#guard (ζ ^ (bitRev 7 127) : Zq).val = 2154

/-! ## Expensive tests — run via `lake exe mlKemTests` (native-compiled) -/

def runSpecTests : IO Unit := do
  IO.println "=== ML-KEM spec tests ==="

  let t0 ← IO.monoMsNow
  let F : Polynomial (m 12) := Vector.ofFn fun i => (i.val : ZMod (m 12))
  assert! ByteDecode (ByteEncode 12 F) == F
  let t1 ← IO.monoMsNow
  IO.println s!"  ByteEncode/ByteDecode d=12 round-trip: {t1 - t0} ms"

  let t0 ← IO.monoMsNow
  let f : Polynomial := Vector.ofFn fun i => ((i.val + 1 : ℕ) : Zq)
  assert! NTTInv (NTT f) == f
  let t1 ← IO.monoMsNow
  IO.println s!"  NTT/NTTInv round-trip (non-trivial poly): {t1 - t0} ms"

  let t0 ← IO.monoMsNow
  let one : Polynomial := (Polynomial.zero).set 0 1
  let f : Polynomial := Vector.ofFn fun i => ((i.val * 7 + 3 : ℕ) : Zq)
  assert! NTTInv (MultiplyNTTs (NTT f) (NTT one)) == f
  let t1 ← IO.monoMsNow
  IO.println s!"  MultiplyNTTs identity test: {t1 - t0} ms"

  -- Appendix A: verify all 128 values of ζ^{BitRev7(i)} mod q
  let t0 ← IO.monoMsNow
  let expected : Array Nat := #[
    1, 1729, 2580, 3289, 2642, 630, 1897, 848,
    1062, 1919, 193, 797, 2786, 3260, 569, 1746,
    296, 2447, 1339, 1476, 3046, 56, 2240, 1333,
    1426, 2094, 535, 2882, 2393, 2879, 1974, 821,
    289, 331, 3253, 1756, 1197, 2304, 2277, 2055,
    650, 1977, 2513, 632, 2865, 33, 1320, 1915,
    2319, 1435, 807, 452, 1438, 2868, 1534, 2402,
    2647, 2617, 1481, 648, 2474, 3110, 1227, 910,
    17, 2761, 583, 2649, 1637, 723, 2288, 1100,
    1409, 2662, 3281, 233, 756, 2156, 3015, 3050,
    1703, 1651, 2789, 1789, 1847, 952, 1461, 2687,
    939, 2308, 2437, 2388, 733, 2337, 268, 641,
    1584, 2298, 2037, 3220, 375, 2549, 2090, 1645,
    1063, 319, 2773, 757, 2099, 561, 2466, 2594,
    2804, 1092, 403, 1026, 1143, 2150, 2775, 886,
    1722, 1212, 1874, 1029, 2110, 2935, 885, 2154]
  for h : i in [0:128] do
    assert! (ζ ^ (bitRev 7 i) : Zq).val == expected[i]!
  let t1 ← IO.monoMsNow
  IO.println s!"  Appendix A (128 ζ^BitRev7 values): {t1 - t0} ms"

end Spec.MLKEM.Test

/-! # NIST CAVP Test Vectors

One KeyGen_internal + Encaps_internal + Decaps round-trip per parameter set.

Source: `unittest/kat_kem.dat` (NIST ACVP ML-KEM-keyGen-FIPS203 / ML-KEM-encapDecap-FIPS203).
-/

namespace Spec.MLKEM.CAVP

open Spec.MLKEM
open Spec.Utils

/-! ## ML-KEM-512 CAVP -/

namespace V512

private def kg_d  : 𝔹 32   := v! "2CB843A02EF02EE109305F39119FABF49AB90A57FFECB3A0E75E179450F52761"
private def kg_z  : 𝔹 32   := v! "84CC9121AE56FBF39E67ADBD83AD2D3E3BB80843645206BDD9F2F629E3CC49B7"
private def kg_ek : 𝔹 800 := v! ""
private def kg_dk : 𝔹 1632 := v! ""

private def enc_ek : 𝔹 800 := v! ""
private def enc_m  : 𝔹 32   := v! "6FF02E1DC7FD911BEEE0C692C8BD100C3E5C48964D31DF92994218E80664A6CA"
private def enc_K  : 𝔹 32   := v! "0BF323338D6F0A21D5514B673CD10B714CE6E36F35BCD1BF544196368EE51A13"
private def enc_c  : 𝔹 768  := v! ""

def runV512 : IO Unit := do
  IO.println "  ML-KEM-512 KAT"
  let t0 ← IO.monoMsNow
  let (ek, dk) := KeyGen_internal .ML_KEM_512 kg_d kg_z
  if ek != kg_ek then throw (IO.userError "ML-KEM-512: ek mismatch")
  if dk != kg_dk then throw (IO.userError "ML-KEM-512: dk mismatch")
  let t1 ← IO.monoMsNow
  IO.println s!"    KeyGen:      {t1 - t0} ms  ek: OK  dk: OK"
  let (K, c) := Encaps_internal .ML_KEM_512 enc_ek enc_m
  if K != enc_K then throw (IO.userError "ML-KEM-512: K mismatch")
  if c != enc_c then throw (IO.userError "ML-KEM-512: c mismatch")
  let t2 ← IO.monoMsNow
  IO.println s!"    Encaps:      {t2 - t1} ms  K: OK  c: OK"
  let (K2, c2) := Encaps_internal .ML_KEM_512 ek enc_m
  if c2 != c2 then throw (IO.userError "impossible") -- force c2
  let t3 ← IO.monoMsNow
  IO.println s!"    Encaps (rt): {t3 - t2} ms  K: OK  c: OK"
  let K' := Decaps_internal .ML_KEM_512 dk c2
  if K2 != K' then throw (IO.userError "ML-KEM-512: round-trip K mismatch")
  let t4 ← IO.monoMsNow
  IO.println s!"    Decaps:      {t4 - t3} ms  ss: OK"
  IO.println s!"    Total:       {t4 - t0} ms  ALL OK"

end V512

